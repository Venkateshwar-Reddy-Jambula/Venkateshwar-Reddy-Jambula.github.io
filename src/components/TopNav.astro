---
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';

interface Link {
  href: string;
  label: string;
}

const primary: Link[] = [
  { href: '/',          label: 'home' },
  { href: '/japan',     label: 'japan' },
  { href: '/pranaalpha', label: 'pranaalpha' },
  { href: '/work',      label: 'work' },
  { href: '/proof',     label: 'public' },
  { href: '/now',       label: 'now' },
  { href: '/about',     label: 'about' },
];

const isActive = (href: string) => {
  if (href === '/') return pathname === '/';
  return pathname === href || pathname.startsWith(href + '/');
};
---

<nav class="topnav" aria-label="Primary">
  <div class="nav-inner">
    <a href="/" class="sig" aria-label="Home">
      <span class="sig-mark" aria-hidden="true"></span>
      <span class="sig-name">Venkateshwar</span>
    </a>
    <ul class="nav-links">
      {primary.map((l) => (
        <li>
          <a href={l.href} class={isActive(l.href) ? 'is-active' : ''}>
            {l.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<style>
  .topnav {
    position: sticky;
    top: 0;
    z-index: 50;
    width: 100%;
    background: rgba(232, 221, 199, 0.88);
    backdrop-filter: saturate(1.1) blur(10px);
    -webkit-backdrop-filter: saturate(1.1) blur(10px);
    border-bottom: 1px solid rgba(60, 40, 20, 0.08);
  }
  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 14px 28px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
  }
  .sig {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    font-family: var(--font-display);
    font-size: 22px;
    color: var(--ink-headline);
    letter-spacing: -0.01em;
    line-height: 1;
  }
  .sig-mark {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--accent-red);
    animation: breathe 2.5s ease infinite;
  }
  @keyframes breathe {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%      { opacity: 0.5; transform: scale(1.15); }
  }
  .sig:hover { text-decoration: none; }

  .nav-links {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 4px;
    align-items: center;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    max-width: 100%;
  }
  .nav-links li { flex-shrink: 0; }
  .nav-links a {
    display: inline-block;
    padding: 7px 12px;
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--ink-primary);
    text-decoration: none;
    border-radius: 4px;
    transition: background 0.2s, color 0.2s;
  }
  .nav-links a:hover {
    color: var(--accent-red);
    text-decoration: none;
  }
  .nav-links a.is-active {
    color: var(--accent-red);
    background: rgba(194, 54, 23, 0.08);
    font-weight: 500;
  }

  @media (max-width: 720px) {
    .nav-inner { padding: 10px 16px; gap: 16px; flex-wrap: wrap; }
    .sig-name { display: none; }
    .nav-links { gap: 2px; }
    .nav-links a { padding: 6px 9px; font-size: 13px; }
  }
</style>
