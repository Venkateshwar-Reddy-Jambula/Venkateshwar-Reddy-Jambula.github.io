<style is:global>
  /* ============ SHARED CHAPTER STYLES ============ */
  .ch {
    max-width: 840px;
    margin: 0 auto;
    padding: 48px 40px 120px;
  }
  .ch-header {
    text-align: center;
    padding: 24px 0 40px;
    margin-bottom: 48px;
    position: relative;
  }
  .ch-back {
    position: absolute;
    top: 0;
    left: 0;
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--ink-muted);
    text-decoration: none;
    padding: 6px 12px;
    background: var(--paper-card);
    border-radius: 3px;
    box-shadow: 0 1px 3px rgba(60, 40, 20, 0.12);
    transition: color 0.2s;
  }
  .ch-back:hover { color: var(--accent-red); text-decoration: none; }
  .ch-eyebrow {
    font-family: var(--font-body);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-muted);
    margin-bottom: 16px;
  }
  .ch h1 {
    font-family: var(--font-display);
    font-size: clamp(72px, 11vw, 128px);
    line-height: 0.9;
    margin: 0;
    letter-spacing: -0.03em;
  }
  .ch-opener {
    max-width: 680px;
    margin: 0 auto 56px;
  }
  .ch-lede {
    font-family: var(--font-display);
    font-size: clamp(22px, 2.8vw, 28px);
    line-height: 1.45;
    color: var(--ink-headline);
    font-style: italic;
    margin: 0;
    text-align: center;
  }
  .ch-lede em { color: var(--accent-red); }
  .ch-section {
    margin: 72px 0;
  }
  .ch-section h2 {
    font-family: var(--font-display);
    font-size: clamp(32px, 4.5vw, 44px);
    line-height: 1.05;
    margin: 0 0 24px;
    letter-spacing: -0.02em;
  }
  .ch-section p {
    font-family: var(--font-body);
    font-size: 17px;
    line-height: 1.8;
    color: var(--ink-primary);
    margin: 0 0 18px;
  }
  .ch-section p em { color: var(--ink-headline); font-style: italic; }
  .ch-section a {
    color: var(--accent-red);
    text-decoration: none;
    border-bottom: 1px solid rgba(194, 54, 23, 0.3);
  }
  .ch-section a:hover { border-bottom-color: var(--accent-red); }

  /* Feature photo (big polaroid) */
  .feature-photo {
    margin: 48px auto 0;
    max-width: 520px;
    padding: 10px 10px 40px;
    background: var(--paper-card);
    box-shadow: 0 2px 4px rgba(60,40,20,0.12), 0 18px 40px rgba(60,40,20,0.2);
    transform: rotate(-1deg);
    position: relative;
    transition: transform 0.3s var(--ease-reveal);
  }
  .feature-photo::before {
    content: '';
    position: absolute;
    top: -12px; left: 50%;
    transform: translateX(-50%) rotate(-3deg);
    width: 90px; height: 22px;
    background: linear-gradient(180deg, rgba(240,230,180,0.72), rgba(240,230,180,0.88));
  }
  .feature-photo:hover { transform: rotate(0deg) translateY(-3px); }
  .feature-photo img {
    display: block; width: 100%; height: 280px;
    object-fit: cover; filter: saturate(0.95) contrast(1.02);
  }
  .feature-photo figcaption {
    position: absolute; bottom: 8px; left: 14px; right: 14px;
    text-align: center;
    font-family: var(--font-hand);
    font-size: 16px;
    color: var(--ink-primary);
    line-height: 1.25;
  }

  /* Gallery (2-3 small images in a row) */
  .gallery {
    display: grid;
    gap: 20px;
    margin-top: 32px;
  }
  .gallery.g-3 { grid-template-columns: repeat(3, 1fr); }
  .gallery.g-2 { grid-template-columns: repeat(2, 1fr); }
  .gallery figure {
    margin: 0;
    background: var(--paper-card);
    padding: 8px 8px 32px;
    box-shadow: 0 2px 4px rgba(60,40,20,0.08), 0 10px 24px rgba(60,40,20,0.12);
    position: relative;
    transition: transform 0.3s var(--ease-reveal);
  }
  .gallery figure:nth-child(odd) { transform: rotate(-1deg); }
  .gallery figure:nth-child(even) { transform: rotate(1deg); }
  .gallery figure:hover { transform: rotate(0deg) translateY(-3px); }
  .gallery img {
    display: block; width: 100%; height: 180px;
    object-fit: cover; filter: saturate(0.9) contrast(1.02);
  }
  .gallery figcaption {
    position: absolute; bottom: 8px; left: 10px; right: 10px;
    text-align: center;
    font-family: var(--font-hand);
    font-size: 14px;
    color: var(--ink-primary);
    line-height: 1.2;
  }

  /* Lesson grid (2x2) */
  .lesson-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }
  .lesson {
    padding: 28px 24px 24px;
    background: var(--paper-card);
    box-shadow: 0 2px 4px rgba(60,40,20,0.08), 0 10px 24px rgba(60,40,20,0.12);
  }
  .l-icon {
    font-family: var(--font-display);
    font-size: 32px; color: var(--accent-red); line-height: 1;
    margin-bottom: 10px;
  }
  .l-label {
    font-family: var(--font-body);
    font-size: 11px; letter-spacing: 0.25em; text-transform: uppercase;
    color: var(--ink-muted); font-weight: 700; margin-bottom: 14px;
  }
  .lesson p {
    font-family: var(--font-body);
    font-size: 14px; line-height: 1.65;
    color: var(--ink-primary); margin: 0;
  }

  /* Close */
  .ch-close blockquote {
    margin: 0;
    padding: 24px 0 24px 28px;
    border-left: 3px solid var(--accent-red);
  }
  .ch-close blockquote p {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(20px, 2.6vw, 24px);
    line-height: 1.5;
    color: var(--ink-headline);
    margin: 0 0 16px;
  }
  .ch-close blockquote p:last-child { margin-bottom: 0; }

  /* Footer */
  .ch-foot {
    margin-top: 80px;
    padding-top: 32px;
    text-align: center;
    border-top: 1px dashed rgba(60, 40, 20, 0.15);
  }
  .ch-back-cta {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--accent-red);
    text-decoration: none;
    font-weight: 600;
    border-bottom: 1px solid rgba(194, 54, 23, 0.3);
  }

  /* Photo credit note */
  .photo-credit {
    font-family: var(--font-body) !important;
    font-size: 11px !important;
    color: var(--ink-muted) !important;
    font-style: italic;
    text-align: center;
    margin: 16px 0 0 !important;
  }

  @media (max-width: 900px) {
    .ch { padding: 32px 20px 80px; }
    .ch-back { position: relative; display: inline-block; margin-bottom: 20px; }
    .lesson-grid { grid-template-columns: 1fr; }
    .gallery.g-3, .gallery.g-2 { grid-template-columns: 1fr; }
  }
</style>
