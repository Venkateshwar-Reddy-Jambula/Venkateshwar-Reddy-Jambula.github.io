---
import BaseLayout from '../layouts/BaseLayout.astro';

// Essays — currently empty. Drop MDX files into src/content/writing/ to populate.
interface EssayDraft {
  title: string;
  note: string;
  status: 'drafting' | 'outlined' | 'planned';
}

const drafts: EssayDraft[] = [
  {
    title: 'Why I wrote a SOUL document for my trading bot',
    note: 'On philosophy docs for AIs, read at every boot.',
    status: 'outlined',
  },
  {
    title: 'Long-horizon agent reliability, explained simply',
    note: "PranaAlpha's thesis without the jargon.",
    status: 'drafting',
  },
  {
    title: 'The four failure modes I design against',
    note: 'Fixation, memory decay, contradiction, reward hacking.',
    status: 'planned',
  },
  {
    title: 'What trading taught me about AI',
    note: 'Discipline, capital preservation, learning rate.',
    status: 'planned',
  },
];
---

<BaseLayout title="Writing — Venkateshwar Reddy Jambula">
  <section class="manuscript">
    <div class="page-header">
      <div class="eyebrow">From the desk of VRJ</div>
      <h1>Writing</h1>
      <p class="lede">
        Essays about agents that forget, markets that fool themselves, and
        reliability that shows up on day three. Nothing published yet &mdash;
        what's in the typewriter today:
      </p>
    </div>

    <div class="typewriter">
      <div class="scroll-bar"></div>

      <div class="typed">
        {drafts.map((d, i) => (
          <article class="entry" style={`--delay: ${i * 100}ms;`}>
            <div class="entry-meta">
              <span class="lineno">{String(i + 1).padStart(2, '0')}</span>
              <span class={`status status-${d.status}`}>{d.status}</span>
            </div>
            <h2>{d.title}</h2>
            <p class="note">{d.note}</p>
          </article>
        ))}

        <div class="signoff">
          <p class="handwrite">more coming. slowly.</p>
          <div class="signature" aria-hidden="true">
            <svg viewBox="0 0 200 50">
              <path d="M10 30 Q 30 10, 50 30 T 90 30 Q 110 15, 130 35 T 170 25 L 195 25"
                    stroke="#c23617" stroke-width="2" fill="none" stroke-linecap="round"
                    stroke-dasharray="400" stroke-dashoffset="400">
                <animate attributeName="stroke-dashoffset" from="400" to="0" dur="2s" begin="1s" fill="freeze"/>
              </path>
            </svg>
          </div>
        </div>
      </div>

      <div class="margin-note">
        <span class="proof">¶</span> drafts update as&nbsp;I write. gitlog is the real history.
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .manuscript {
    min-height: 100vh;
    padding: 60px 40px 120px;
    max-width: 920px;
    margin: 0 auto;
  }

  .page-header {
    text-align: center;
    margin-bottom: 48px;
  }
  .eyebrow {
    font-family: var(--font-body);
    font-size: 11px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--ink-muted);
    margin-bottom: 16px;
  }
  .page-header h1 {
    font-size: clamp(56px, 9vw, 96px);
    margin: 0 0 20px;
    line-height: 0.9;
  }
  .page-header .lede {
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.6;
    color: var(--ink-muted);
    max-width: 560px;
    margin: 0 auto;
  }

  /* ============ TYPEWRITER PAGE ============ */
  .typewriter {
    background: #fdfcf4;
    padding: 80px 80px 100px 110px;
    box-shadow:
      0 2px 4px rgba(60,40,20,0.1),
      0 20px 50px rgba(60,40,20,0.18);
    position: relative;
    /* Ruled lines like typewriter paper */
    background-image:
      repeating-linear-gradient(180deg, transparent 0 30px, rgba(120,100,60,0.08) 30px 31px);
    font-family: 'JetBrains Mono', 'Courier New', monospace;
  }

  /* Red margin line, like old typewriter paper */
  .scroll-bar {
    position: absolute;
    left: 72px;
    top: 0;
    bottom: 0;
    width: 1px;
    background: rgba(194, 54, 23, 0.4);
  }

  .entry {
    margin-bottom: 40px;
    opacity: 0;
    transform: translateY(12px);
    animation: typeIn 0.5s var(--ease-reveal) forwards;
    animation-delay: calc(var(--delay) + 200ms);
  }
  @keyframes typeIn {
    to { opacity: 1; transform: translateY(0); }
  }

  .entry-meta {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 8px;
  }
  .lineno {
    font-size: 13px;
    color: var(--ink-muted);
    letter-spacing: 0.05em;
  }
  .status {
    font-size: 10px;
    font-family: var(--font-body);
    padding: 2px 8px;
    border-radius: 2px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-weight: 700;
  }
  .status-drafting { background: rgba(194, 54, 23, 0.15); color: var(--accent-red); }
  .status-outlined { background: rgba(194, 54, 23, 0.05); color: #8a3a22; border: 1px solid rgba(194, 54, 23, 0.2); }
  .status-planned  { background: rgba(100, 100, 100, 0.08); color: var(--ink-muted); }

  .entry h2 {
    font-family: 'JetBrains Mono', 'Courier New', monospace;
    font-size: 22px;
    line-height: 1.3;
    color: var(--ink-headline);
    margin: 0 0 8px;
    font-weight: 700;
    letter-spacing: -0.01em;
  }
  .entry .note {
    font-size: 15px;
    color: var(--ink-muted);
    margin: 0;
    line-height: 1.55;
  }

  .signoff {
    margin-top: 64px;
    padding-top: 24px;
    border-top: 1px dashed rgba(60, 40, 20, 0.2);
  }
  .signoff .handwrite {
    font-family: var(--font-hand);
    font-size: 26px;
    color: var(--ink-primary);
    margin: 0 0 8px;
  }
  .signoff .signature {
    width: 180px;
  }

  .margin-note {
    position: absolute;
    right: 24px;
    top: 80px;
    font-family: var(--font-hand);
    font-size: 15px;
    color: var(--accent-red);
    max-width: 160px;
    transform: rotate(4deg);
    line-height: 1.2;
  }
  .margin-note .proof {
    font-family: 'Courier New', serif;
    font-size: 22px;
    display: inline-block;
    margin-right: 2px;
    font-weight: 700;
  }

  @media (max-width: 900px) {
    .typewriter { padding: 40px 24px 60px 36px; }
    .scroll-bar { left: 24px; }
    .entry h2 { font-size: 18px; }
    .margin-note { display: none; }
  }
</style>
