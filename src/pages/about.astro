---
import BaseLayout from '../layouts/BaseLayout.astro';

// House rules Venkat writes and actually works by.
const values = [
  'Honesty over comfort.',
  'Capital preservation is love, not fear.',
  'Learning over rule-following.',
  'No celebration before verification.',
  'Admit unknowns by default.',
  'Show work, not process.',
];

const languages = [
  { name: 'Telugu',   level: 'native' },
  { name: 'Hindi',    level: 'native' },
  { name: 'English',  level: 'professional' },
  { name: 'Kannada',  level: 'limited' },
  { name: 'Japanese', level: 'elementary' },
  { name: 'Tamil',    level: 'elementary' },
];
---

<BaseLayout title="About — Venkateshwar Reddy Jambula">
  <section class="endpaper">
    <!-- Ornate initial cap + bio -->
    <article class="bio">
      <div class="eyebrow">a longer version</div>
      <h1>About.</h1>

      <div class="drop-cap">
        <span class="cap">I</span> grew up in Hyderabad, studied Instrumentation
        Engineering at <a href="https://cvr.ac.in" target="_blank" rel="noopener">CVR College</a>
        (2007&ndash;2011), and have mostly been doing one thing ever since:
        trying to make systems a little more trustworthy than they were
        the day before.
      </div>

      <p>
        My first job was at <strong>Bosch</strong>, writing safety-critical
        C for engine ECUs. About a year of that time was spent travelling
        to Yokohama on projects with Kubota, HINO, and Mitsubishi, and
        that single year left its own mark. From there I went into
        data science at <strong>Caterpillar</strong> (CNNs for PCB
        inspection), led the function at <strong>Continental</strong>
        for four and a half years (supply-chain RL, Bayesian optimisation,
        first time I led a team), ran Bixby voice as Chief Data Scientist
        at <strong>Samsung R&amp;D</strong>, took a year off to build an
        automated trading system solo, and spent a year at
        <strong>Sigmoid</strong> shipping enterprise GenAI before starting
        PranaAlpha Labs in May 2025.
      </p>

      <p>
        Outside work, I read slowly, reply slowly, and care more about
        the long tail of a system than its first impression. Japan left
        a permanent mark &mdash; more than I can fit in a bio.
      </p>

      <p>
        I believe the next several years of AI will be decided not by
        who trains the biggest model but by who stays the most trustworthy
        on day three. That&rsquo;s the bet I&rsquo;m working on.
      </p>
    </article>

    <!-- Values block -->
    <aside class="values">
      <div class="v-label">House rules</div>
      <ol>
        {values.map((v, i) => (
          <li>
            <span class="num">{String(i + 1).padStart(2, '0')}</span>
            <span>{v}</span>
          </li>
        ))}
      </ol>
      <p class="v-source">
        These are the rules I actually work by &mdash; not performative,
        load-bearing.
      </p>
    </aside>

    <!-- Languages -->
    <aside class="languages">
      <div class="v-label">Languages spoken</div>
      <ul>
        {languages.map((l) => (
          <li>
            <span class="lang-name">{l.name}</span>
            <span class="lang-level">{l.level}</span>
          </li>
        ))}
      </ul>
    </aside>

    <!-- Contact -->
    <aside class="contact">
      <div class="v-label">Contact</div>
      <ul>
        <li>
          <span class="c-what">email</span>
          <a href="mailto:venkateshwar.jambula@gmail.com">venkateshwar.jambula@gmail.com</a>
        </li>
        <li>
          <span class="c-what">linkedin</span>
          <a href="https://www.linkedin.com/in/venkateshwar-jambula" target="_blank" rel="noopener">venkateshwar-jambula</a>
        </li>
        <li>
          <span class="c-what">github</span>
          <a href="https://github.com/Venkateshwar-Reddy-Jambula" target="_blank" rel="noopener">Venkateshwar-Reddy-Jambula</a>
        </li>
        <li>
          <span class="c-what">company</span>
          <a href="https://www.pranaalpha.com" target="_blank" rel="noopener">pranaalpha.com</a>
        </li>
      </ul>
    </aside>

    <!-- Colophon proper -->
    <footer class="colophon">
      <div class="ornament" aria-hidden="true">✦ &middot; ✦</div>
    </footer>
  </section>
</BaseLayout>

<style>
  .endpaper {
    max-width: 800px;
    margin: 0 auto;
    padding: 80px 48px 120px;
    background: #fdfbf2;
    background-image:
      url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='200' height='200'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='2' stitchTiles='stitch'/><feColorMatrix values='0 0 0 0 0.4  0 0 0 0 0.3  0 0 0 0 0.2  0 0 0 0.05 0'/></filter><rect width='200' height='200' filter='url(%23n)'/></svg>");
    box-shadow:
      0 2px 4px rgba(60,40,20,0.08),
      0 20px 60px rgba(60,40,20,0.15);
    margin-top: 40px;
    margin-bottom: 60px;
    position: relative;
  }

  /* Decorative corners */
  .endpaper::before, .endpaper::after {
    content: '✦';
    position: absolute;
    color: var(--accent-red);
    font-size: 16px;
    opacity: 0.4;
  }
  .endpaper::before { top: 20px; left: 20px; }
  .endpaper::after { bottom: 20px; right: 20px; }

  .bio {
    margin-bottom: 56px;
  }
  .eyebrow {
    font-family: var(--font-body);
    font-size: 11px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--ink-muted);
    text-align: center;
    margin-bottom: 12px;
  }
  .bio h1 {
    font-size: clamp(64px, 10vw, 96px);
    text-align: center;
    margin: 0 0 48px;
    line-height: 0.9;
  }

  .drop-cap {
    font-family: var(--font-body);
    font-size: 17px;
    line-height: 1.7;
    color: var(--ink-primary);
    margin-bottom: 24px;
  }
  .drop-cap .cap {
    font-family: var(--font-display);
    font-size: 72px;
    line-height: 0.8;
    float: left;
    margin: 4px 12px 0 0;
    color: var(--accent-red);
  }

  .bio p {
    font-family: var(--font-body);
    font-size: 17px;
    line-height: 1.7;
    color: var(--ink-primary);
    margin: 0 0 20px;
  }
  .bio a {
    color: var(--accent-red);
    text-decoration: none;
    border-bottom: 1px solid rgba(194, 54, 23, 0.4);
    transition: border-bottom-color 0.2s;
  }
  .bio a:hover { border-bottom-color: var(--accent-red); }
  .bio strong {
    color: var(--ink-headline);
    font-weight: 600;
  }

  /* ============ ASIDES (values, languages, contact) ============ */
  .values, .languages, .contact {
    margin: 48px 0;
    padding: 28px 32px;
    background: var(--paper-bg);
    border-radius: 4px;
    box-shadow: inset 0 0 0 1px rgba(60, 40, 20, 0.08);
  }
  .v-label {
    font-family: var(--font-body);
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--accent-red);
    font-weight: 700;
    margin-bottom: 16px;
  }

  .values ol {
    list-style: none;
    padding: 0;
    margin: 0;
    counter-reset: value-counter;
  }
  .values li {
    display: flex;
    align-items: baseline;
    gap: 16px;
    padding: 8px 0;
    border-bottom: 1px dashed rgba(60, 40, 20, 0.08);
    font-family: var(--font-display);
    font-size: 20px;
    line-height: 1.4;
    color: var(--ink-primary);
    font-style: italic;
  }
  .values li:last-child { border-bottom: none; }
  .values .num {
    font-family: var(--font-body);
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--accent-red);
    font-weight: 700;
    font-style: normal;
    width: 22px;
    flex-shrink: 0;
  }
  .v-source {
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--ink-muted);
    margin: 16px 0 0;
    font-style: italic;
  }
  .v-source code {
    background: rgba(60, 40, 20, 0.08);
    padding: 1px 5px;
    border-radius: 2px;
    font-size: 11px;
  }

  .languages ul, .contact ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 8px;
  }
  .languages ul { grid-template-columns: repeat(2, 1fr); }
  .languages li {
    display: flex;
    justify-content: space-between;
    padding: 6px 0;
    font-family: var(--font-body);
    font-size: 14px;
    border-bottom: 1px dashed rgba(60, 40, 20, 0.08);
  }
  .languages .lang-name {
    color: var(--ink-primary);
    font-weight: 500;
  }
  .languages .lang-level {
    color: var(--ink-muted);
    font-size: 12px;
    font-style: italic;
  }

  .contact li {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 8px 0;
    border-bottom: 1px dashed rgba(60, 40, 20, 0.08);
  }
  .contact .c-what {
    font-family: var(--font-body);
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--ink-muted);
    font-weight: 600;
  }
  .contact a {
    color: var(--accent-red);
    text-decoration: none;
    font-family: var(--font-body);
    font-size: 14px;
    border-bottom: 1px solid rgba(194, 54, 23, 0.4);
  }

  /* ============ COLOPHON ============ */
  .colophon {
    margin-top: 64px;
    text-align: center;
    padding-top: 32px;
    border-top: 1px dashed rgba(60, 40, 20, 0.15);
  }
  .ornament {
    font-size: 14px;
    color: var(--accent-red);
    letter-spacing: 0.3em;
    opacity: 0.6;
    margin-bottom: 16px;
  }
  .colophon p {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--ink-muted);
    line-height: 1.7;
    margin: 0 auto 12px;
    max-width: 560px;
  }
  .colophon p em { color: var(--ink-primary); font-style: italic; }
  .colophon .small { font-size: 12px; }
  .colophon a { color: var(--accent-red); }

  @media (max-width: 900px) {
    .endpaper {
      padding: 40px 24px 60px;
      margin-top: 20px;
    }
    .languages ul { grid-template-columns: 1fr; }
  }
</style>
