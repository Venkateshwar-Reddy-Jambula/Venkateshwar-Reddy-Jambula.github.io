---
import BaseLayout from '../layouts/BaseLayout.astro';

const lessons = [
  {
    icon: '▣',
    label: 'real-time systems',
    body: 'My first code ran inside moving vehicles. The bug wasn\'t a stack trace — it was a dashboard warning light flickering on a truck in Yokohama. Reliability stopped being abstract the moment lives shared the road with my branch.',
  },
  {
    icon: '⧉',
    label: 'specifications matter',
    body: 'Four years on ECU software taught me that an ambiguous spec doesn\'t just cause bugs — it causes expensive ones you find three countries away, in production. Write the ambiguity out before the code. Every time.',
  },
  {
    icon: '◐',
    label: 'two engineering cultures',
    body: 'Working between German rigor and Japanese craft taught me something: process and precision aren\'t opposed. They\'re two different answers to the same question — how do you make something that doesn\'t lie to its users?',
  },
  {
    icon: '⌘',
    label: 'the protocol layer',
    body: 'CAN, UDS, KWP, J1939 — the boring, unglamorous protocols that keep trucks, tractors, and diesel engines talking to themselves reliably across decades. My first taste of "the hardest problems live in the plumbing."',
  },
];

const clients = [
  { name: 'Kubota',                 focus: 'tractor & engine ECU software',           years: '2012 – 2015', img: '/images/bosch/kubota-tractor.jpg',    alt: 'Kubota tractor' },
  { name: 'HINO Motors',            focus: 'heavy-duty diesel engine calibration',    years: '2013 – 2015', img: '/images/bosch/hino-truck.jpg',        alt: 'HINO hybrid cargo truck' },
  { name: 'Mitsubishi Heavy Ind.',  focus: 'engine & exhaust subsystem integration',  years: '2014 – 2015', img: '/images/bosch/mitsubishi-engine.jpg', alt: 'Mitsubishi 4N15 diesel engine' },
];

const stack = [
  { label: 'Languages',  value: 'C · Embedded C · some Python' },
  { label: 'Protocols',  value: 'CAN · UDS · KWP · J1939' },
  { label: 'Tools',      value: 'CANalyzer · CANoe · INCA · Simulink' },
  { label: 'Domain',     value: 'Engine ECUs · exhaust subsystems · emissions' },
  { label: 'Team size',  value: '8–12 engineers, 3 countries' },
  { label: 'Cycle time', value: 'weeks, not days' },
];
---

<BaseLayout title="Bosch — Venkateshwar Reddy Jambula">
  <article class="ch">

    <!-- Header -->
    <header class="ch-header">
      <a href="/" class="ch-back">&larr; home</a>
      <div class="ch-eyebrow">2011–2015 &middot; the first job &middot; the four years that taught me how to code for consequences</div>
      <h1>Bosch.</h1>
    </header>

    <!-- Opening pull + ECU feature photo -->
    <section class="ch-opener">
      <p class="ch-lede">
        I joined Bosch right out of college, twenty-two, assuming I&rsquo;d
        write code that ran on laptops. Four years later I was writing code
        that ran inside <em>trucks</em> &mdash; and getting my first lessons
        from engineers whose bugs end up on actual roads.
      </p>

      <figure class="feature-photo">
        <img src="/images/bosch/ecu.jpg" alt="An automotive ECU (engine control unit)" loading="eager" />
        <figcaption>
          an ECU &mdash; the small, stubborn, safety-critical computer my C
          code lived inside
        </figcaption>
      </figure>
    </section>

    <!-- Main story -->
    <section class="ch-section">
      <h2>A different kind of software.</h2>
      <p>
        My first job was engine and exhaust subsystem development for
        automotive ECUs. If that sounds dry, you haven&rsquo;t met the
        people who do it. Every line of C I wrote at Bosch went through
        code review, static analysis, MISRA compliance checks, functional
        safety reviews, and a test harness that simulated conditions I
        wouldn&rsquo;t see in my actual life. And then, only then, did
        it go into a truck.
      </p>
      <p>
        The people I worked with had been doing this for twenty years.
        They knew exactly how long it takes to diagnose a software-reset
        bug at forty degrees Celsius in a diesel engine running at
        four thousand RPM in a rice field in Hokkaido. They taught me
        without ceremony. I was very young and very lucky.
      </p>
      <p>
        The international projects &mdash; Kubota, HINO, MHI &mdash;
        meant flying between Bangalore and Yokohama. The Bosch office
        in Yokohama became a second home. That chapter is
        <a href="/japan">its own story</a>. But the Bosch chapter is the
        one where I learned that real-time, safety-critical software
        exists in a fundamentally different universe than most web apps,
        and that universe has something to teach everybody.
      </p>
    </section>

    <!-- Four lessons -->
    <section class="ch-section">
      <h2>What Bosch put in me forever.</h2>
      <div class="lesson-grid">
        {lessons.map((l) => (
          <article class="lesson">
            <div class="l-icon" aria-hidden="true">{l.icon}</div>
            <div class="l-label">{l.label}</div>
            <p>{l.body}</p>
          </article>
        ))}
      </div>
    </section>

    <!-- Clients -->
    <section class="ch-section">
      <h2>Who I built for.</h2>
      <ul class="client-list">
        {clients.map((c) => (
          <li>
            <figure class="cl-photo">
              <img src={c.img} alt={c.alt} loading="lazy" />
            </figure>
            <div class="cl-body">
              <div class="cl-name">{c.name}</div>
              <div class="cl-focus">{c.focus}</div>
              <div class="cl-years">{c.years}</div>
            </div>
          </li>
        ))}
      </ul>
      <p class="photo-credit">
        Photos: Wikimedia Commons (CC-BY-SA). Not my own.
      </p>
    </section>

    <!-- Stack facts -->
    <section class="ch-section">
      <h2>The stack, for anyone who cares.</h2>
      <dl class="stack">
        {stack.map((s) => (
          <div class="st-row">
            <dt>{s.label}</dt>
            <dd>{s.value}</dd>
          </div>
        ))}
      </dl>
    </section>

    <!-- Bridge forward -->
    <section class="ch-section ch-close">
      <blockquote>
        <p>
          I left Bosch in 2015 to chase data science at Caterpillar. But
          every safety-critical instinct I still have &mdash;
          defensive programming, distrust of clean numbers, insistence on
          provable behaviour over performative progress &mdash; traces
          back to those four years on engine ECUs.
        </p>
        <p>
          PortoAI is a consumer product, not a diesel engine. But if it
          ever deserves the trust of users with real money on the line,
          it&rsquo;ll be because I carried Bosch&rsquo;s instincts into
          the LLM era and didn&rsquo;t let them go.
        </p>
      </blockquote>
    </section>

    <footer class="ch-foot">
      <a href="/" class="ch-back-cta">&larr; back to the story</a>
    </footer>
  </article>
</BaseLayout>

<style>
  .ch {
    max-width: 840px;
    margin: 0 auto;
    padding: 48px 40px 120px;
  }

  /* ============ HEADER ============ */
  .ch-header {
    text-align: center;
    padding: 24px 0 40px;
    margin-bottom: 48px;
    position: relative;
  }
  .ch-back {
    position: absolute;
    top: 0;
    left: 0;
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--ink-muted);
    text-decoration: none;
    padding: 6px 12px;
    background: var(--paper-card);
    border-radius: 3px;
    box-shadow: 0 1px 3px rgba(60, 40, 20, 0.12);
    transition: color 0.2s;
  }
  .ch-back:hover { color: var(--accent-red); text-decoration: none; }
  .ch-eyebrow {
    font-family: var(--font-body);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-muted);
    margin-bottom: 16px;
  }
  .ch h1 {
    font-family: var(--font-display);
    font-size: clamp(72px, 11vw, 128px);
    line-height: 0.9;
    margin: 0;
    letter-spacing: -0.03em;
  }

  /* ============ OPENER ============ */
  .ch-opener {
    max-width: 680px;
    margin: 0 auto 56px;
  }
  .ch-lede {
    font-family: var(--font-display);
    font-size: clamp(22px, 2.8vw, 28px);
    line-height: 1.45;
    color: var(--ink-headline);
    font-style: italic;
    margin: 0;
    text-align: center;
  }
  .ch-lede em { color: var(--accent-red); }

  /* ============ SECTIONS ============ */
  .ch-section {
    margin: 72px 0;
  }
  .ch-section h2 {
    font-family: var(--font-display);
    font-size: clamp(32px, 4.5vw, 44px);
    line-height: 1.05;
    margin: 0 0 24px;
    letter-spacing: -0.02em;
  }
  .ch-section p {
    font-family: var(--font-body);
    font-size: 17px;
    line-height: 1.8;
    color: var(--ink-primary);
    margin: 0 0 18px;
  }
  .ch-section p em {
    font-style: italic;
    color: var(--ink-headline);
  }
  .ch-section a {
    color: var(--accent-red);
    text-decoration: none;
    border-bottom: 1px solid rgba(194, 54, 23, 0.3);
    padding-bottom: 1px;
  }
  .ch-section a:hover { border-bottom-color: var(--accent-red); text-decoration: none; }

  /* ============ LESSON GRID ============ */
  .lesson-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }
  .lesson {
    padding: 28px 24px 24px;
    background: var(--paper-card);
    box-shadow: 0 2px 4px rgba(60, 40, 20, 0.08), 0 10px 24px rgba(60, 40, 20, 0.12);
  }
  .l-icon {
    font-family: var(--font-display);
    font-size: 32px;
    color: var(--accent-red);
    line-height: 1;
    margin-bottom: 10px;
  }
  .l-label {
    font-family: var(--font-body);
    font-size: 11px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--ink-muted);
    font-weight: 700;
    margin-bottom: 14px;
  }
  .lesson p {
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.65;
    color: var(--ink-primary);
    margin: 0;
  }

  /* ============ FEATURE PHOTO (ECU in opener) ============ */
  .feature-photo {
    margin: 48px auto 0;
    max-width: 520px;
    padding: 10px 10px 40px;
    background: var(--paper-card);
    box-shadow:
      0 2px 4px rgba(60, 40, 20, 0.12),
      0 18px 40px rgba(60, 40, 20, 0.2);
    transform: rotate(-1deg);
    position: relative;
    transition: transform 0.3s var(--ease-reveal);
  }
  .feature-photo::before {
    content: '';
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%) rotate(-3deg);
    width: 90px;
    height: 22px;
    background: linear-gradient(180deg, rgba(240, 230, 180, 0.72), rgba(240, 230, 180, 0.88));
    border-left: 1px dashed rgba(120, 100, 60, 0.18);
    border-right: 1px dashed rgba(120, 100, 60, 0.18);
  }
  .feature-photo:hover { transform: rotate(0deg) translateY(-3px); }
  .feature-photo img {
    display: block;
    width: 100%;
    height: 280px;
    object-fit: cover;
    filter: saturate(0.95) contrast(1.02);
  }
  .feature-photo figcaption {
    position: absolute;
    bottom: 8px;
    left: 14px;
    right: 14px;
    text-align: center;
    font-family: var(--font-hand);
    font-size: 17px;
    color: var(--ink-primary);
    line-height: 1.25;
  }

  /* ============ CLIENTS ============ */
  .client-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .client-list li {
    background: var(--paper-card);
    box-shadow: 0 2px 4px rgba(60, 40, 20, 0.08), 0 10px 24px rgba(60, 40, 20, 0.12);
    overflow: hidden;
    transition: transform 0.3s var(--ease-reveal), box-shadow 0.3s;
  }
  .client-list li:hover {
    transform: translateY(-4px);
    box-shadow: 0 4px 8px rgba(60, 40, 20, 0.12), 0 20px 40px rgba(60, 40, 20, 0.18);
  }
  .cl-photo {
    margin: 0;
    height: 180px;
    overflow: hidden;
    background: #1a1410;
  }
  .cl-photo img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(0.9) contrast(1.05);
    transition: transform 0.4s var(--ease-reveal);
  }
  .client-list li:hover .cl-photo img { transform: scale(1.04); }
  .cl-body { padding: 18px 20px 20px; }
  .cl-name {
    font-family: var(--font-display);
    font-size: 22px;
    color: var(--ink-headline);
    margin-bottom: 8px;
    line-height: 1.1;
  }
  .cl-focus {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--ink-primary);
    line-height: 1.5;
    margin-bottom: 10px;
  }
  .cl-years {
    font-family: var(--font-body);
    font-size: 11px;
    letter-spacing: 0.15em;
    color: var(--ink-muted);
  }
  .photo-credit {
    font-family: var(--font-body);
    font-size: 11px !important;
    color: var(--ink-muted) !important;
    font-style: italic;
    text-align: center;
    margin: 20px 0 0 !important;
  }

  /* ============ STACK ============ */
  .stack {
    margin: 0;
    padding: 0;
    border-top: 1px dashed rgba(60, 40, 20, 0.15);
  }
  .st-row {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 24px;
    padding: 12px 0;
    border-bottom: 1px dashed rgba(60, 40, 20, 0.12);
  }
  .st-row dt {
    font-family: var(--font-body);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-muted);
    font-weight: 700;
    margin: 0;
  }
  .st-row dd {
    font-family: var(--font-body);
    font-size: 15px;
    color: var(--ink-headline);
    margin: 0;
    line-height: 1.5;
  }

  /* ============ CLOSE ============ */
  .ch-close blockquote {
    margin: 0;
    padding: 24px 0 24px 28px;
    border-left: 3px solid var(--accent-red);
  }
  .ch-close blockquote p {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(20px, 2.6vw, 24px);
    line-height: 1.5;
    color: var(--ink-headline);
    margin: 0 0 16px;
  }
  .ch-close blockquote p:last-child { margin-bottom: 0; }

  /* ============ FOOTER ============ */
  .ch-foot {
    margin-top: 80px;
    padding-top: 32px;
    text-align: center;
    border-top: 1px dashed rgba(60, 40, 20, 0.15);
  }
  .ch-back-cta {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--accent-red);
    text-decoration: none;
    font-weight: 600;
    border-bottom: 1px solid rgba(194, 54, 23, 0.3);
    padding-bottom: 2px;
  }
  .ch-back-cta:hover { text-decoration: none; border-bottom-color: var(--accent-red); }

  /* ============ MOBILE ============ */
  @media (max-width: 900px) {
    .ch { padding: 32px 20px 80px; }
    .ch-back { position: relative; display: inline-block; margin-bottom: 20px; }
    .lesson-grid { grid-template-columns: 1fr; }
    .client-list { grid-template-columns: 1fr; }
    .st-row { grid-template-columns: 1fr; gap: 4px; }
  }
</style>
